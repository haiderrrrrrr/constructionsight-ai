# Environment
ENV=development
COOKIE_SECURE=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=constructionsight
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# JWT security
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=30
REFRESH_TOKEN_EXP_MINUTES=10080
JWT_ISSUER=constructionsight-ai
JWT_AUDIENCE=constructionsight-client
JWT_KEY_ID=current

# Rate limits
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SIGNUP=3/minute
RATE_LIMIT_REFRESH=10/minute

# Login protection
LOGIN_FAIL_WINDOW_MINUTES=15
LOGIN_FAIL_THRESHOLD=10
LOCKOUT_THRESHOLD=5
LOCKOUT_BASE_MINUTES=5
LOCKOUT_MULTIPLIER=2
LOCKOUT_MAX_MINUTES=60

# CORS / frontend
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Cookie settings
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SAMESITE=lax

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gmail SMTP
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Camera credential encryption
CAMERA_ENCRYPTION_KEY=

# Camera health scheduler
CAMERA_SCHEDULER_ENABLED=true
CAMERA_SCHEDULER_INTERVAL_MINUTES=5

# Project defaults
REPORT_FREQUENCY=weekly

# Webhooks
WEBHOOK_API_KEY=

# Background jobs
CELERY_ENABLED=false
REDIS_URL=

# OpenWeatherMap
OPENWEATHER_API_KEY=

# Admin seed
SEED_ADMIN_FULL_NAME=System Administrator
SEED_ADMIN_EMAIL=
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=
SEED_ADMIN_RESET_PASSWORD=0

# Hugging Face / AI
HF_TOKEN=
SMART_QUERY_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_MODEL=deepseek-coder:6.7b
